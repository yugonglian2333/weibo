# ============================================================
# 微博超话签到 + AI 发帖 — 环境变量配置
# ============================================================
# 使用方法: 复制此文件为 .env 并填入真实值
#   cp .env.example .env
#
# 注意: .env 已在 .gitignore 中排除，不会被提交到仓库
# ============================================================

# ---- 微博 Cookie（必填）----
# 获取方式:
#   1. 用 Chrome 登录 weibo.com 或 m.weibo.cn
#   2. 按 F12 → Application → Cookies → 全选复制所有 Cookie
#   3. 粘贴到下方
WEIBO_COOKIE=你的微博Cookie粘贴在这里

# ---- AI 内容生成（可选，不配置则只签到不发帖）----
# AI 服务商: mimo / claude / openai
AI_PROVIDER=mimo
AI_API_KEY=你的AI_API_Key
# API 地址（使用默认值时可以不填）
# AI_API_BASE=https://api.xiaomimimo.com/v1
# 模型名称（使用默认值时可以不填）
# AI_MODEL=mimo-chat

# ---- 通知推送（可选，不配置则不发通知）----
# 通知渠道: pushplus / serverchan / telegram
# PushPlus: https://www.pushplus.plus/ 微信扫码获取 Token
# Server酱: https://sct.ftqq.com/ 微信扫码获取 SendKey
# Telegram: 向 @BotFather 创建 Bot 获取 Token
NOTIFY_PROVIDER=pushplus
NOTIFY_TOKEN=你的通知渠道Token
# Telegram 专属: chat_id（其他渠道无需设置）
# NOTIFY_CHAT_ID=你的Telegram_chat_id
